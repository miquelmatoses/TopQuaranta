{
	# Rebràs avisos d'expiració i errors d'emissió
	email admin@topquaranta.cat
}

# — Apex → WWW (canònic)
topquaranta.cat {
    # envia HSTS també en la redirecció de l'apex
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    }
    redir https://www.topquaranta.cat{uri} 301
}

# — Lloc principal (new web)
www.topquaranta.cat {
	encode zstd gzip

	# Static files
	handle_path /static/* {
		root * /home/topquaranta/app/staticfiles
		file_server
	}

	# All public routes → new web (port 8083)
	handle {
		reverse_proxy 127.0.0.1:8083
	}

	# Security headers
	header {
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		# S6: explicit CSP. Directives:
		#   default-src 'self'         — everything not listed below must
		#                                come from the same origin
		#   script-src                 — D3 from cdnjs (SRI-pinned in mapa.html);
		#                                'unsafe-inline' kept because staff
		#                                templates still have inline handlers —
		#                                follow-up task: move to external files
		#                                or use nonces.
		#   style-src                  — Google Fonts stylesheet (imported by
		#                                mm-design typography.css); unsafe-inline
		#                                for the many style="" attributes.
		#   font-src                   — Google Fonts actual font files.
		#   img-src                    — album art from Deezer CDN + arbitrary
		#                                https for future sources; data: for SVG.
		#   connect-src                — fetch() only to same origin.
		#   frame-ancestors            — redundant with X-Frame-Options DENY;
		#                                sent for modern browsers.
		#   form-action                — forms can only submit to same origin.
		#   base-uri                   — prevents <base> tag injection from
		#                                redirecting relative URLs.
		#   object-src 'none'          — no Flash/Java/plugin embeds.
		#   upgrade-insecure-requests  — transparent http→https upgrade.
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self'; frame-ancestors 'none'; form-action 'self'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests"
	}
	log {
		output file /var/log/caddy/topquaranta_access.log {
			roll_size 10MiB
			roll_keep 5
		}
	}
}
